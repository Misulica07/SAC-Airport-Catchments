# Copy this file to `.env` and fill in real values. Never commit `.env`.

# OpenRouteService API key — sign up at https://openrouteservice.org/dev/#/signup
ORS_API_KEY=replace-me

# Optional: TfL Open Data app key (Phase 2)
# Register at https://api.tfl.gov.uk/
TFL_APP_KEY=

# Optional: Nomis API user agent string for UK Census downloads (Phase 2)
NOMIS_USER_AGENT=westminster-airport-catchment-research
