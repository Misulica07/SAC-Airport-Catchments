# --- Data ------------------------------------------------------------------
# Keep folder structure but exclude raw / processed payloads from version control.
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# --- Logs ------------------------------------------------------------------
logs/
*.log
